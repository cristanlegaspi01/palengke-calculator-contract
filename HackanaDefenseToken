pragma solidity ^0.8.0;

// Task: Import the industry-standard ERC20 implementation
import "@openzeppelin/contracts/token/ERC20/ERC20.sol";

/**
 * @title HackanaDefenseToken
 * @notice A secure community currency built on audited OpenZeppelin foundations.
 */
contract HackanaDefenseToken is ERC20 {

    /**
     * @notice Task: Initialize the token and mint the initial supply.
     * @dev The constructor calls the parent ERC20 constructor with ("Name", "Symbol").
     */
    constructor() ERC20("DefenseToken", "DEF") {
        // Task: Mint 1000 tokens to the deployer (Neri/Barangay).
        // 'decimals()' is usually 18, so we multiply by 10^18 for precision.
        _mint(msg.sender, 1000 * 10 ** decimals());
    }
}
