pragma solidity ^0.8.0;

contract BarangayFund {

    uint256 public totalFunds;

    // Event declaration
    event FundUpdated(uint256 newAmount, address updatedBy);

    /**
     * @notice Deposit funds to the barangay fund
     */
    function depositFunds(uint256 amount) public {
        require(amount > 0, "Deposit amount must be greater than zero.");

        totalFunds += amount;

        // Emit event para makita ang update
        emit FundUpdated(totalFunds, msg.sender);
    }

    /**
     *  BONUS: Withdraw funds (optional, admin-style)
     */
    function withdrawFunds(uint256 amount) public {
        require(amount > 0, "Invalid amount");
        require(amount <= totalFunds, "Insufficient funds");

        totalFunds -= amount;

        emit FundUpdated(totalFunds, msg.sender);
    }

    /**
     *  BONUS: View total funds (kahit automatic na)
     */
    function getTotalFunds() public view returns (uint256) {
        return totalFunds;
    }
}
