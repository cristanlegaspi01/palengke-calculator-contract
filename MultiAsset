pragma solidity ^0.8.0;

// Task: Import the Multi-Token standard and Access Control
import "@openzeppelin/contracts/token/ERC1155/ERC1155.sol";
import "@openzeppelin/contracts/access/Ownable.sol";

/**
 * @title MultiAsset
 * @notice The ultimate defensive contract, managing both currency and unique items efficiently.
 */
contract MultiAsset is ERC1155, Ownable {
    // Defining the "ID" for each type of asset
    uint256 public constant GOLD = 1;     // Fungible (Like currency)
    uint256 public constant ARTIFACT = 2; // Non-fungible (Unique item)

    /**
     * @notice Task: Initialize with Metadata URI and mint initial supplies.
     * @dev The URI uses the {id} placeholder to automatically point to the right metadata.
     */
    constructor() 
        ERC1155("https://api.bitskwela.com/metadata/{id}.json") 
        Ownable(msg.sender) 
    {
        // 1. Mint 1000 Gold Coins to the sender
        _mint(msg.sender, GOLD, 1000, "");
        
        // 2. Mint 1 Special Artifact to the sender
        _mint(msg.sender, ARTIFACT, 1, "");
    }

    /**
     * @notice Task: Allow the owner to mint more assets as needed.
     * @param to The recipient of the tokens.
     * @param id The ID of the asset (GOLD or ARTIFACT).
     * @param amount How many to mint.
     * @param data Optional extra data.
     */
    function mint(
        address to, 
        uint256 id, 
        uint256 amount, 
        bytes memory data
    ) public onlyOwner {
        _mint(to, id, amount, data);
    }
}
