pragma solidity ^0.8.0;

/**
 * @title BarangayServiceFees
 * @notice Manages and calculates fees for barangay services using View and Pure functions.
 */
contract BarangayServiceFees {

    uint256 public barangayIdFee = 50;
    uint256 public barangayClearanceFee = 100;

    /**
     * @notice Returns the Barangay ID fee.
     * @dev Like checking the "listahan" for the price. Uses 'view' to read state.
     */
    function getBarangayIdFee() public view returns (uint256) {
        return barangayIdFee;
    }

    /**
     * @notice Returns the Barangay Clearance fee.
     * @dev Uses 'view' because it accesses the state variable barangayClearanceFee.
     */
    function getBarangayClearanceFee() public view returns (uint256) {
        return barangayClearanceFee;
    }

    /**
     * @notice Calculates total cost for multiple IDs.
     * @dev To be 'pure', it must not read 'barangayIdFee' directly from storage.
     * Instead, we pass the rate as an input or perform the math independently.
     */
    function calculateTotalIdCost(uint256 _quantity, uint256 _feePerUnit) public pure returns (uint256) {
        // Pure logic: result depends ONLY on the parameters provided.
        return _quantity * _feePerUnit;
    }
}
